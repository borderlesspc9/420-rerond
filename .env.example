# Copie para `.env` na raiz e ajuste se necessário.
# Postgres local (docker compose up -d):
DATABASE_URL="postgresql://rerond:rerond@localhost:5433/rerond?schema=public"

PORT=3001
PUBLIC_BASE_URL=http://localhost:3001

# Frontend (Vite) — opcional; sem isso o solicitacaoService usa http://localhost:3001/api
VITE_API_BASE_URL=http://localhost:3001/api

# IA (pelo menos uma, conforme o provider em uso)
# OPENAI_API_KEY=
